{
  "expo": {
    "name": "赛博包工头",
    "slug": "sbbgt-mobile",
    "version": "0.0.31",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": ["sbbgt", "orca"],
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.onlyyu.sbbgt.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "赛博包工头需要通过本地网络连接桌面端。",
        "NSMicrophoneUsageDescription": "允许赛博包工头录制语音，并在已配对的桌面端完成转写。",
        "NSPhotoLibraryUsageDescription": "允许赛博包工头把照片附加到已配对桌面端的终端会话。",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "100.64.0.0/10": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "fd7a:115c:a1e0::/48": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        },
        "ITSAppUsesNonExemptEncryption": false,
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ]
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111111"
      },
      "usesCleartextTraffic": true,
      "allowBackup": false,
      "permissions": ["RECORD_AUDIO", "MODIFY_AUDIO_SETTINGS"],
      "package": "com.onlyyu.sbbgt.mobile",
      "versionCode": 8
    },
    "plugins": [
      "expo-router",
      "./plugins/android-respect-rotation-lock.js",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#111111"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "允许赛博包工头使用相机扫描配对二维码。",
          "microphonePermission": "允许赛博包工头录制语音，并发送到已配对桌面端进行转写。",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "允许赛博包工头把照片附加到已配对桌面端的终端会话。"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true
          },
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ]
  }
}
